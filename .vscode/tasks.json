{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/TeamsApi.sln"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "test",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/TeamsApi.Tests/TeamsApi.Tests.csproj",
        "--no-build"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "swift: Build TeamsApiMenuBarHost",
      "type": "process",
      "command": "swift",
      "args": [
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/TeamsApi.MenuBarHost"
      },
      "group": "build"
    },
    {
      "label": "swift: Run TeamsApiMenuBarHost",
      "type": "process",
      "command": "swift",
      "args": [
        "run"
      ],
      "options": {
        "cwd": "${workspaceFolder}/TeamsApi.MenuBarHost"
      }
    }
  ]
}
